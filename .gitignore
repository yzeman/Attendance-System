# ============================================
# SMART ATTENDANCE SYSTEM - .gitignore
# ============================================

# Environment variables (IMPORTANT: Never commit these!)
.env
.env.local
.env.*.local
!.env.example

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.vite/
.DS_Store

# TypeScript cache
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# System files
Thumbs.db
.DS_Store

# Optional npm cache
.npm/
.eslintcache
.stylelintcache

# Yarn files
.yarn-integrity
.pnp.*
.yarn/*

# Serverless
.serverless/

# Firebase
.firebase/

# Next.js (if you ever use it)
.next/
out/

# Parcel
.cache/
.parcel-cache

# Vuepress
.vuepress/dist
.temp/

# Sveltekit
.svelte-kit/

# Gatsby
.cache/
